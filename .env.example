# Aimee Robot Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets!

# ─────────────────────────────── Robot Identity ───────────────────────────────
# IMPORTANT: Each robot in your fleet needs a UNIQUE name and device ID.
# Example fleet: ron (board #1), minnie (board #2), wren (board #3)
AIMEE_ROBOT_NAME=ron
AIMEE_DEVICE_ID=arduino-uno-q-001

# ─────────────────────────────── Cloud Services ───────────────────────────────
# AimeeCloud MQTT endpoint (override if self-hosting)
AIMEE_CLOUD_ENDPOINT=https://aimeecloud.com
AIMEE_CLOUD_BROKER_HOST=aimeecloud.com
AIMEE_CLOUD_BROKER_PORT=443

# Lemonfox.ai API key (for TTS and Whisper STT fallback)
# Get yours at: https://www.lemonfox.ai/
LEMONFOX_API_KEY=

# ─────────────────────────────── Hardware ───────────────────────────────
# OBSBOT Tiny 2 camera (USB RNDIS default)
OBSBOT_IP=192.168.5.1
OBSBOT_PORT=16284

# RoArm M3 arm (WiFi or serial)
ROARM_IP=
ROARM_SERIAL_PORT=/dev/ttyUSB0

# UGV02 base (serial)
UGV02_SERIAL_PORT=/dev/ttyACM0

# ─────────────────────────────── Audio ───────────────────────────────
# ALSA audio device card index (usually 0 for USB sound cards)
ALSA_CARD_INDEX=0

# ─────────────────────────────── Robot Configuration ───────────────────────────────
# Path to YAML robot config file (drives which hardware nodes are launched)
# Defaults to src/aimee_bringup/config/robots/<hostname>.yaml
# ROBOT_CONFIG=/workspace/config/robots/minnie.yaml

# ─────────────────────────────── Advanced ───────────────────────────────
# ROS2 Domain ID (keep unique per robot fleet to avoid crosstalk)
# If running multiple robots on the same Wi-Fi network, give each a different ID.
# Ron=42, Minnie=43, Wren=44, etc.
ROS_DOMAIN_ID=42

# Cyclone DDS is now the default RMW (replaced Fast DDS for Nav2 stability)
FASTRTPS_PROFILE=

# Session persistence path
AIMEE_SESSION_FILE=/home/arduino/.config/aimee_session.json
