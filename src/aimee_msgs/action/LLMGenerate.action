# LLM Generation Action
# Server: LLM Action Server
# Clients: Intent Router, Skills

# Goal: Request for LLM generation
string prompt             # User prompt
string system_context     # System prompt/persona
int32 max_tokens          # Maximum tokens to generate (default: 150)
float32 temperature       # Sampling temperature (default: 0.7)
bool stream               # Enable streaming feedback (default: true)
string session_id         # Session identifier for context
---
# Result: Final generation result
string response           # Complete generated text
bool success            # True if generation succeeded
string error_message      # Error details if failed
float32 generation_time   # Time taken in seconds
int32 tokens_generated    # Total tokens generated
int32 tokens_input        # Input prompt tokens
---
# Feedback: Streaming updates during generation
string partial_response   # Cumulative text so far
int32 tokens_generated    # Tokens generated so far
int32 tokens_total        # Estimated total tokens
bool is_complete          # True if generation finished
string current_word       # Currently generating word (optional)
