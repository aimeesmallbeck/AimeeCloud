# Skill Execution Action
# Server: Skill Manager
# Clients: Intent Router

# Goal: Request to execute a skill
string skill_id           # Skill identifier
string user_input         # User's command/text
RobotState robot_state    # Current robot state
string user_context       # JSON string with user context
string session_id         # Session identifier
---
# Result: Skill execution result
bool success
string response_text      # Text response from skill
string tts_audio_path     # Path to TTS audio file (if generated)
string error_message

# Actions performed
MotorAction[] motor_actions
CameraAction[] camera_actions
LEDAction[] led_actions
---
# Feedback: Execution progress updates
string status             # "starting" | "executing" | "finalizing"
string current_action     # Description of current action
float32 progress          # 0.0 to 1.0
bool can_cancel           # Whether skill can be cancelled now
